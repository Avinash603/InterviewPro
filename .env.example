# ============================================================
#  InterviewPro — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars   # generate: openssl rand -base64 32

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/interviewpro?schema=public
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/interviewpro

# ── OAuth Providers ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI Providers ─────────────────────────────────────────────
# Groq (free tier available) — https://console.groq.com
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI (optional, for embeddings) — https://platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Vector DB ─────────────────────────────────────────────────
# Pinecone — https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX=interviewpro-memory

# ── Redis ─────────────────────────────────────────────────────
# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Voice AI ──────────────────────────────────────────────────
# VAPI — https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_WEB_TOKEN=
NEXT_PUBLIC_VAPI_WORKFLOW_ID=

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
